<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>

   <!-- Preference initializer -->
   <extension point="org.eclipse.core.runtime.preferences">
      <initializer class="io.github.kaluchi.jdtbridge.ui.preferences.PreferenceInitializer"/>
   </extension>

   <!-- Preference page -->
   <extension point="org.eclipse.ui.preferencePages">
      <page id="io.github.kaluchi.jdtbridge.ui.preferences"
            name="JDT Bridge"
            class="io.github.kaluchi.jdtbridge.ui.preferences.BridgePreferencePage"/>
   </extension>

   <!-- Commands -->
   <extension point="org.eclipse.ui.commands">
      <category id="io.github.kaluchi.jdtbridge.ui.category"
                name="JDT Bridge"/>
      <command id="io.github.kaluchi.jdtbridge.ui.commands.healthCheck"
               name="Health Check"
               categoryId="io.github.kaluchi.jdtbridge.ui.category"/>
      <command id="io.github.kaluchi.jdtbridge.ui.commands.openTerminal"
               name="Open Terminal"
               categoryId="io.github.kaluchi.jdtbridge.ui.category"/>
      <command id="io.github.kaluchi.jdtbridge.ui.commands.newAgent"
               name="New Agent..."
               categoryId="io.github.kaluchi.jdtbridge.ui.category"/>
   </extension>

   <!-- Handlers -->
   <extension point="org.eclipse.ui.handlers">
      <handler commandId="io.github.kaluchi.jdtbridge.ui.commands.healthCheck"
               class="io.github.kaluchi.jdtbridge.ui.commands.HealthCheckHandler"/>
      <handler commandId="io.github.kaluchi.jdtbridge.ui.commands.openTerminal"
               class="io.github.kaluchi.jdtbridge.ui.commands.OpenTerminalHandler"/>
      <handler commandId="io.github.kaluchi.jdtbridge.ui.commands.newAgent"
               class="io.github.kaluchi.jdtbridge.ui.commands.NewAgentHandler"/>
   </extension>

   <!-- Main menu -->
   <extension point="org.eclipse.ui.menus">
      <menuContribution locationURI="menu:org.eclipse.ui.main.menu?after=additions">
         <menu id="io.github.kaluchi.jdtbridge.ui.menu"
               label="JDT Bridge"
               mnemonic="J">
            <command commandId="io.github.kaluchi.jdtbridge.ui.commands.newAgent"
                     label="New Agent..."
                     icon="icons/new-agent.svg"/>
            <separator name="configs" visible="true"/>
            <dynamic id="io.github.kaluchi.jdtbridge.ui.menu.agentConfigs"
                     class="io.github.kaluchi.jdtbridge.ui.menus.AgentConfigsContribution"/>
            <separator name="tools" visible="true"/>
            <command commandId="io.github.kaluchi.jdtbridge.ui.commands.healthCheck"
                     label="Health Check"
                     icon="icons/health-check.svg"/>
            <command commandId="io.github.kaluchi.jdtbridge.ui.commands.openTerminal"
                     label="Open Terminal"
                     icon="icons/terminal.svg"/>
         </menu>
      </menuContribution>

      <!-- Context menu on projects -->
      <menuContribution locationURI="popup:org.eclipse.ui.popup.any?after=additions">
         <menu id="io.github.kaluchi.jdtbridge.ui.popup.menu"
               label="JDT Bridge">
            <command commandId="io.github.kaluchi.jdtbridge.ui.commands.openTerminal"
                     label="Open Terminal Here"
                     icon="icons/terminal.svg"/>
            <visibleWhen checkEnabled="false">
               <with variable="selection">
                  <iterate ifEmpty="false" operator="and">
                     <adapt type="org.eclipse.core.resources.IProject"/>
                  </iterate>
               </with>
            </visibleWhen>
         </menu>
      </menuContribution>
   </extension>

   <!-- Startup handler (welcome check) -->
   <extension point="org.eclipse.ui.startup">
      <startup class="io.github.kaluchi.jdtbridge.ui.WelcomeStartupHandler"/>
   </extension>

   <!-- Agent launch configuration type (run only, no debug) -->
   <extension point="org.eclipse.debug.core.launchConfigurationTypes">
      <launchConfigurationType
            id="io.github.kaluchi.jdtbridge.ui.agentLaunchType"
            name="JDT Bridge Agent"
            delegate="io.github.kaluchi.jdtbridge.ui.launch.AgentLaunchDelegate"
            modes="run"
            public="true"/>
   </extension>

   <extension point="org.eclipse.debug.ui.launchConfigurationTypeImages">
      <launchConfigurationTypeImage
            configTypeID="io.github.kaluchi.jdtbridge.ui.agentLaunchType"
            icon="icons/agent.svg"/>
   </extension>

   <extension point="org.eclipse.debug.ui.launchConfigurationTabGroups">
      <launchConfigurationTabGroup
            id="io.github.kaluchi.jdtbridge.ui.agentTabGroup"
            type="io.github.kaluchi.jdtbridge.ui.agentLaunchType"
            class="io.github.kaluchi.jdtbridge.ui.launch.AgentTabGroup"/>
   </extension>

</plugin>

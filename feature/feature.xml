      version="2.1.0.qualifier"
      provider-name="%feature.provider_name"
      plugin="io.github.kaluchi.jdtbridge.branding"
      image="feature.png">

   <description url="%description.url">
      %description.text
   </description>

   <copyright>
      %copyright.text
   </copyright>

   <license url="https://www.apache.org/licenses/LICENSE-2.0">
